# Study route, get PROLIFIC_PID, STUDY_ID and SESSION_ID from URL parameters
# This route will assign a task to a participant and return the HTML interface for that task
# It *should* be updated to allow the participant to continue where they left off if they refresh the page - this will be implemented using the PROLIFIC_PID searching on pending tasks.
# TODO: Some kind of handling for case where there are no tasks left for that worker - i.e there are tasks left but none that they haven't already completed
@app.route('/study/', methods=['GET', 'POST'])
def study():

    print("routed to study")
    prolific_pid = request.args.get('PROLIFIC_PID')
    session_id = request.args.get('SESSION_ID')

    print(prolific_pid, session_id)
    # Read the HTML template file
    #with open('html/interface.html', 'r') as html_file:
    #    html_content = html_file.read()

    # Allocate task or find already allocated task
    
    if prolific_pid is None or session_id is None:
        return "PROLIFIC_PID and SESSION_ID are required parameters.", 400
    else:
        task_id, list_id = allocate_task(prolific_pid, session_id)

        # If there is a database error, return the error message and status code
        if task_id == "Database Error - Please try again, if the problem persists contact us." and list_id == -1:
            print("could not allocate task due to database error")
            return task_id, 500


        # If no task is available, return a message
        if task_id is None:
            return "No tasks available", 400
        



        # mechanism for preparing data for jinja template, randomize order, etc.

        trial_keys = list(rom_data[int(list_id)].keys())

        random.shuffle(trial_keys)

        print("shuffled_trials: ", trial_keys)
        #random.seed(datetime.now().timestamp())
        template_data = [rom_data[int(list_id)][x] for x in trial_keys]



        print(os.getcwd())
        #html_content = preprocess_html(html_content, df.iloc[[list_id]], task_id) # Params: html_content, df, task_id=-1
        #html_content += f'<input type="hidden" id="prolific_pid" value="{prolific_pid}">'
        #html_content += f'<input type="hidden" id="session_id" value="{session_id}">'
        return render_template("interface.html", session_id=session_id, task_id=task_id, list_id = list_id, prolific_pid=prolific_pid, data=template_data)
        #return redirect(url_for('/study', session_id=session_id, task_id=task_id, list_id = list_id, prolific_pid=prolific_pid, data=template_data))

